# ============================================================================
# FA-iForest 集群部署 — 环境变量
# Cluster deployment environment variables
# ============================================================================
# 用法 / Usage:
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 按实际阿里云内网 IP 填写 NODE_*_IP
#   3. 所有脚本(0-prepare-local.sh / 1-sync-to-nodes.sh 等)会自动 source .env
#
# 重要 / Important:
#   - NODE_*_IP 必须填阿里云"内网 IP"(同 VPC 内通信免流量费), 不是公网 IP
#   - SSH_USER 必须能免密 sudo, 或者用 root (省事但有安全风险)
# ============================================================================

# ---------- 节点拓扑 / Node topology ----------
# 3 节点最小集群: master 跑 ZK + Kafka broker-1 + Flink JM + Prom + Grafana
#                worker 跑 Kafka broker-N + Flink TM
NODE_MASTER_IP=172.16.0.11
NODE_WORKER1_IP=172.16.0.12
NODE_WORKER2_IP=172.16.0.13

# 节点公网 IP(仅用于本地 ssh 跳板), 阿里云 ECS 默认会有一个弹性公网
NODE_MASTER_PUBLIC_IP=
NODE_WORKER1_PUBLIC_IP=
NODE_WORKER2_PUBLIC_IP=

# SSH 用户(本地 → 节点), 需要免密登录 + sudo 权限
SSH_USER=root
SSH_KEY=~/.ssh/id_rsa

# ---------- 组件版本 / Component versions ----------
# 严格对齐项目 pom.xml: Flink 1.13.6 + Kafka 2.6.3
ZK_VERSION=3.6.3
KAFKA_VERSION=2.6.3
KAFKA_SCALA_VERSION=2.12
FLINK_VERSION=1.13.6
FLINK_SCALA_VERSION=2.12
JDK_BASE_IMAGE=eclipse-temurin:8-jre-jammy

# ---------- 远端工作目录 / Remote working directory ----------
# 所有 docker-compose / jar / 数据集落到这个目录(各节点一致)
REMOTE_HOME=/opt/fa-iforest

# ---------- Flink 资源 / Flink resources ----------
# JobManager: 1 个, 在 master 节点
JM_HEAP_MB=1024
# TaskManager: 每节点 1 个, slots 数 = 节点 CPU 数(worker 4c 即 slots=4)
TM_SLOTS=4
TM_HEAP_MB=4096
TM_MANAGED_MEM_MB=1024

# ---------- Kafka 资源 / Kafka resources ----------
KAFKA_HEAP_OPTS="-Xms512m -Xmx1024m"

# ---------- Topic 设计 / Topic design ----------
# 这 6 个名字来自代码 (LocalProcessor / CoordinatorJob 的 default), 不要乱改 --
# 改了的话, 必须同时改两个 Java main 类的默认值, 或者每次 submit job 都传 --xxxTopic.
# 方向二(a) Phase 3 之后:
#   - drift-topic (DriftReport) 已废,被 feature-drift-topic (FeatureDrift) 取代
#   - source-topic 单独有 SOURCE_PARTITIONS (Fork 1 = 1,保 per-feature 顺序;
#     Fork 2/EXP3 升 P_d 个 partition 才接多 sender 交织)
#   - tree-topic / model-topic / feature-drift-topic / drift-round-topic 都是协议性 topic, 量不大
#   - output-scores 是结果落盘, Phase 1 不追求高吞吐
#   - 后续要扩并行: kafka-topics.sh --alter --partitions N (随时改, 不是单向门)
TOPIC_SOURCE=source-topic
TOPIC_TREE=tree-topic
TOPIC_MODEL=model-topic
TOPIC_SCORE=output-scores
TOPIC_FEATURE_DRIFT=feature-drift-topic
TOPIC_DRIFT_ROUND=drift-round-topic

# 所有 topic 统一 partition / replication
TOPIC_PARTITIONS=1
TOPIC_REPLICATION=2
# source-topic 单独的 partition (Fork 1 v1 = 1;Fork 2/EXP3 升 P_d)
SOURCE_PARTITIONS=1

# ---------- 监控 / Monitoring (可选, 推荐) ----------
ENABLE_MONITORING=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ---------- Job 配置 / Job submission ----------
JOB_JAR_NAME=FA-iForest-1.0-SNAPSHOT.jar

# 两个 Flink Job (代码里分别是 main 类)
JOB_LOCAL_MAIN=com.leejean.main.LocalProcessor
JOB_COORDINATOR_MAIN=com.leejean.main.CoordinatorJob

# 并行度: Coordinator 内部强制 setParallelism(1), 这里写 1 保持一致
# LocalProcessor 用 8 (= 2 worker x 4 slot)
JOB_LOCAL_PARALLELISM=8
JOB_COORDINATOR_PARALLELISM=1

# LocalProcessor 模型参数 (代码 default 对齐)
JOB_TOTAL_TREES=100
JOB_SUBSAMPLE_SIZE=256
JOB_RING_BUFFER_SIZE=1000

# CoordinatorJob 投票超时 (代码 default 5000ms)
JOB_VOTING_TIMEOUT_MS=5000

# 检测面参数 (方向二(a) Phase 3),暂用 LocalProcessor 代码 default, 以后调参再加在这里 /
# Detection-side params: use code defaults for now, add here when tuning later.
#   LocalProcessor:  --iksWindowSize --iksPValue --confirmWin --ksConfirm
#                    --detectionParallelism --cooldownSamples --zThresholdK --pauseMode
#   CoordinatorJob:  --aggK --aggWin --refractory
