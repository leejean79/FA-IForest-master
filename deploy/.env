# ============================================================================
# FA-iForest 集群部署 — 环境变量
# Cluster deployment environment variables
# ============================================================================
# 用法 / Usage:
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 按实际阿里云内网 IP 填写 NODE_*_IP
#   3. 所有脚本(0-prepare-local.sh / 1-sync-to-nodes.sh 等)会自动 source .env
#
# 重要 / Important:
#   - NODE_*_IP 必须填阿里云"内网 IP"(同 VPC 内通信免流量费), 不是公网 IP
#   - SSH_USER 必须能免密 sudo, 或者用 root (省事但有安全风险)
# ============================================================================

# ---------- 节点拓扑 / Node topology ----------
# 3 节点最小集群: master 跑 ZK + Kafka broker-1 + Flink JM + Prom + Grafana
#                worker 跑 Kafka broker-N + Flink TM
NODE_MASTER_IP=172.16.0.162
NODE_WORKER1_IP=172.16.0.163
NODE_WORKER2_IP=172.16.0.164

# 节点公网 IP(仅用于本地 ssh 跳板), 阿里云 ECS 默认会有一个弹性公网
NODE_MASTER_PUBLIC_IP=47.120.79.17
NODE_WORKER1_PUBLIC_IP=8.155.160.129
NODE_WORKER2_PUBLIC_IP=47.121.27.199

# SSH 用户(本地 → 节点), 需要免密登录 + sudo 权限
SSH_USER=root
SSH_KEY=/Users/lijing/Documents/scripts/test/fa-iforest-key.pem

# ---------- 组件版本 / Component versions ----------
# 严格对齐项目 pom.xml: Flink 1.13.6 + Kafka 2.6.3
ZK_VERSION=3.6.3
KAFKA_VERSION=2.6.3
KAFKA_SCALA_VERSION=2.12
FLINK_VERSION=1.13.6
FLINK_SCALA_VERSION=2.12
JDK_BASE_IMAGE=eclipse-temurin:8-jre-jammy

# ---------- 远端工作目录 / Remote working directory ----------
# 所有 docker-compose / jar / 数据集落到这个目录(各节点一致)
REMOTE_HOME=/opt/fa-iforest

# ---------- Flink 资源 / Flink resources ----------
# JobManager: 1 个, 在 master 节点
JM_HEAP_MB=1024
# TaskManager: 每节点 1 个, slots 数 = 节点 CPU 数(worker 4c 即 slots=4)
TM_SLOTS=4
TM_HEAP_MB=4096
TM_MANAGED_MEM_MB=1024

# ---------- Kafka 资源 / Kafka resources ----------
KAFKA_HEAP_OPTS="-Xms512m -Xmx1024m"
# 总并行度(= worker 数 × TM_SLOTS), 用于设置多 partition topic 的 partition 数
#TOTAL_PARALLELISM=8

# ---------- Topic 设计 / Topic design ----------
# 方向二(a) Phase 3 之后:drift-topic 已废,被 feature-drift-topic 取代
TOPIC_SOURCE=source-topic
TOPIC_TREE=tree-topic
TOPIC_MODEL=model-topic
TOPIC_SCORE=output-scores
TOPIC_FEATURE_DRIFT=feature-drift-topic
TOPIC_DRIFT_ROUND=drift-round-topic

TOPIC_PARTITIONS=1
TOPIC_SCORE_PARTITIONS=4
TOPIC_REPLICATION=2
# source-topic 单独的 partition (Fork 1 v1 = 1;Fork 2/EXP3 升 P_d)
SOURCE_PARTITIONS=1

# ---------- 监控 / Monitoring (可选, 推荐) ----------
ENABLE_MONITORING=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ---------- Job 配置 / Job submission ----------
JOB_JAR_NAME=FA-iForest-1.0-SNAPSHOT.jar

JOB_LOCAL_MAIN=com.leejean.main.LocalProcessor
JOB_COORDINATOR_MAIN=com.leejean.main.CoordinatorJob

JOB_LOCAL_PARALLELISM=4
JOB_COORDINATOR_PARALLELISM=1

JOB_TOTAL_TREES=100
JOB_SUBSAMPLE_SIZE=256
JOB_RING_BUFFER_SIZE=1000

JOB_VOTING_TIMEOUT_MS=5000
JOB_LOAD_RATE=2000

# 检测面默认 (per-feature IKS + 聚合器, 方向二(a) Phase 3)
JOB_IKS_WINDOW_SIZE=2000
JOB_IKS_PVALUE=0.001
JOB_AGG_K=3
